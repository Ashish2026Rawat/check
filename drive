<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DriveMate India — Peer-to-Peer Car Sharing</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0a0a0a;
  --white: #fafaf8;
  --cream: #f5f2eb;
  --orange: #e8500a;
  --orange-light: #ff6b2b;
  --orange-pale: #fff2ec;
  --charcoal: #1c1c1c;
  --gray-dark: #333;
  --gray-mid: #666;
  --gray-light: #aaa;
  --gray-pale: #e8e8e4;
  --font-display: 'Syne', sans-serif;
  --font-body: 'DM Sans', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--white);
  color: var(--black);
  overflow-x: hidden;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.2rem 3rem;
  background: rgba(250,250,248,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
.nav-logo {
  font-family: var(--font-display);
  font-size: 1.4rem; font-weight: 800;
  color: var(--black);
  letter-spacing: -0.03em;
}
.nav-logo span { color: var(--orange); }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a {
  font-size: 0.875rem; font-weight: 400;
  color: var(--gray-dark); text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--orange); }
.nav-cta {
  background: var(--black); color: var(--white);
  padding: 0.6rem 1.4rem; border-radius: 2px;
  font-size: 0.875rem; font-weight: 500;
  text-decoration: none; transition: background 0.2s;
  font-family: var(--font-body);
}
.nav-cta:hover { background: var(--orange); }

/* ── HERO ── */
#home {
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 0 3rem 5rem;
  position: relative;
  overflow: hidden;
  background: var(--black);
}
.hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 70% 40%, #1a1a1a 0%, #0a0a0a 100%);
}
.hero-grid {
  position: absolute; inset: 0;
  background-image: 
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 60px 60px;
}
.hero-accent {
  position: absolute; top: 8%; right: -5%;
  width: 55vw; height: 55vw; max-width: 700px; max-height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,80,10,0.15) 0%, transparent 70%);
  pointer-events: none;
}
.hero-tag {
  position: relative;
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(232,80,10,0.15);
  border: 1px solid rgba(232,80,10,0.3);
  color: var(--orange-light);
  padding: 0.4rem 1rem; border-radius: 2px;
  font-size: 0.8rem; font-weight: 500; letter-spacing: 0.05em;
  text-transform: uppercase; margin-bottom: 1.5rem;
}
.hero-tag::before {
  content: ''; width: 6px; height: 6px; background: var(--orange-light); border-radius: 50%;
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

.hero-h1 {
  position: relative;
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 8vw, 7rem);
  font-weight: 800; line-height: 0.95;
  color: var(--white);
  letter-spacing: -0.04em;
  max-width: 900px;
  margin-bottom: 1.5rem;
}
.hero-h1 em {
  font-style: normal; color: var(--orange);
  display: block;
}
.hero-sub {
  position: relative;
  max-width: 500px;
  font-size: 1.1rem; font-weight: 300;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
  margin-bottom: 2.5rem;
}
.hero-actions { position: relative; display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
.btn-primary {
  background: var(--orange); color: var(--white);
  padding: 0.9rem 2rem; border-radius: 2px;
  font-family: var(--font-body); font-size: 0.95rem; font-weight: 500;
  text-decoration: none; border: none; cursor: pointer;
  transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px;
}
.btn-primary:hover { background: var(--orange-light); transform: translateY(-1px); }
.btn-outline {
  background: transparent; color: rgba(255,255,255,0.7);
  padding: 0.9rem 2rem; border-radius: 2px;
  border: 1px solid rgba(255,255,255,0.15);
  font-family: var(--font-body); font-size: 0.95rem; font-weight: 400;
  text-decoration: none; cursor: pointer;
  transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px;
}
.btn-outline:hover { border-color: rgba(255,255,255,0.4); color: var(--white); }
.hero-stats {
  position: relative;
  display: flex; gap: 3rem;
  margin-top: 4rem; padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.hero-stat-num {
  font-family: var(--font-display);
  font-size: 2rem; font-weight: 700; color: var(--white);
}
.hero-stat-lbl { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-top: 2px; }

/* ── SECTION SHARED ── */
section { padding: 6rem 3rem; }
.section-label {
  font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--orange);
  margin-bottom: 0.75rem;
}
.section-h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700; line-height: 1.1;
  letter-spacing: -0.03em; color: var(--black);
  max-width: 700px; margin-bottom: 1rem;
}
.section-h2.light { color: var(--white); }
.section-sub {
  font-size: 1rem; color: var(--gray-mid); line-height: 1.7;
  max-width: 580px; margin-bottom: 3rem;
}
.section-sub.light { color: rgba(255,255,255,0.5); }

/* ── HOW IT WORKS ── */
#how { background: var(--cream); }
.steps-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1px; background: rgba(0,0,0,0.08); border: 1px solid rgba(0,0,0,0.08);
}
.step {
  background: var(--cream); padding: 2.5rem 2rem;
  position: relative; transition: background 0.2s;
}
.step:hover { background: var(--white); }
.step-num {
  font-family: var(--font-display);
  font-size: 4rem; font-weight: 800; color: rgba(0,0,0,0.06);
  line-height: 1; margin-bottom: 1.5rem;
}
.step-icon {
  width: 48px; height: 48px; border-radius: 2px;
  background: var(--black); display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; margin-bottom: 1rem;
}
.step h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; }
.step p { font-size: 0.875rem; color: var(--gray-mid); line-height: 1.65; }

/* ── SEARCH BAR ── */
.search-block {
  background: var(--white); border: 1px solid var(--gray-pale);
  border-radius: 2px; padding: 1.5rem 2rem;
  display: grid; grid-template-columns: 1fr 1fr 1fr auto;
  gap: 1rem; align-items: end; max-width: 900px; margin: 0 auto 4rem;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.field label { font-size: 0.75rem; font-weight: 500; color: var(--gray-mid); display: block; margin-bottom: 6px; letter-spacing: 0.04em; text-transform: uppercase; }
.field input, .field select {
  width: 100%; padding: 0.65rem 0.8rem;
  border: 1px solid var(--gray-pale); border-radius: 2px;
  font-family: var(--font-body); font-size: 0.9rem; color: var(--black);
  background: var(--white); outline: none;
  transition: border-color 0.2s;
}
.field input:focus, .field select:focus { border-color: var(--orange); }

/* ── CAR LISTINGS ── */
#cars { background: var(--white); }
.cars-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}
.car-card {
  border: 1px solid var(--gray-pale); border-radius: 2px;
  overflow: hidden; cursor: pointer;
  transition: all 0.25s;
}
.car-card:hover { border-color: var(--orange); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
.car-img {
  height: 200px; background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  font-size: 5rem; position: relative; overflow: hidden;
}
.car-img-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--cream) 0%, #ece8df 100%);
}
.car-badge {
  position: absolute; top: 12px; left: 12px;
  background: var(--black); color: var(--white);
  padding: 3px 8px; font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.05em; text-transform: uppercase; border-radius: 1px;
}
.car-badge.new { background: var(--orange); }
.car-emoji { position: relative; font-size: 5rem; }
.car-info { padding: 1.25rem; }
.car-make { font-family: var(--font-display); font-size: 1rem; font-weight: 600; }
.car-meta { font-size: 0.8rem; color: var(--gray-mid); margin-top: 2px; margin-bottom: 12px; }
.car-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
.tag {
  font-size: 0.7rem; padding: 3px 8px; border-radius: 1px;
  background: var(--cream); color: var(--gray-dark);
  font-weight: 500; letter-spacing: 0.02em;
}
.car-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 12px; border-top: 1px solid var(--gray-pale); }
.car-price { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; }
.car-price span { font-size: 0.75rem; font-weight: 400; color: var(--gray-mid); }
.car-rating { font-size: 0.8rem; color: var(--gray-mid); display: flex; align-items: center; gap: 4px; }
.star { color: #f59e0b; }

/* ── EARN ── */
#earn { background: var(--black); color: var(--white); }
.earn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.earn-visual {
  background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
  border-radius: 2px; padding: 2rem;
}
.earn-calc-row { display: flex; justify-content: space-between; align-items: center; padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.earn-calc-row:last-child { border-bottom: none; font-size: 1.1rem; font-weight: 500; }
.earn-calc-label { font-size: 0.875rem; color: rgba(255,255,255,0.5); }
.earn-calc-val { font-family: var(--font-display); font-weight: 600; color: var(--white); }
.earn-calc-val.highlight { color: var(--orange); font-size: 1.4rem; }
.income-slider-wrap { margin: 1.5rem 0; }
.income-slider-wrap label { font-size: 0.8rem; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8px; }
.income-slider {
  width: 100%; accent-color: var(--orange);
  height: 4px; cursor: pointer;
}
.earn-features { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 2rem; }
.earn-feat { display: flex; gap: 1rem; align-items: flex-start; }
.earn-feat-icon { width: 36px; height: 36px; background: rgba(232,80,10,0.15); border: 1px solid rgba(232,80,10,0.25); border-radius: 2px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1rem; }
.earn-feat h4 { font-size: 0.9rem; font-weight: 500; margin-bottom: 3px; }
.earn-feat p { font-size: 0.8rem; color: rgba(255,255,255,0.45); line-height: 1.6; }

/* ── BUSINESS PLAN ── */
#plan { background: var(--white); }
.plan-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--gray-pale); margin-bottom: 3rem; overflow-x: auto; }
.plan-tab {
  padding: 0.9rem 1.5rem; font-size: 0.875rem; font-weight: 500;
  cursor: pointer; border-bottom: 2px solid transparent;
  color: var(--gray-mid); white-space: nowrap; transition: all 0.15s;
}
.plan-tab.active { color: var(--black); border-bottom-color: var(--orange); }
.plan-tab:hover:not(.active) { color: var(--black); }
.plan-content { display: none; }
.plan-content.active { display: block; }

/* financials */
.fin-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2.5rem; }
.fin-card {
  border: 1px solid var(--gray-pale); padding: 1.25rem;
  border-radius: 2px;
}
.fin-card .val { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: var(--black); }
.fin-card .lbl { font-size: 0.75rem; color: var(--gray-mid); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
.fin-card.accent { background: var(--black); border-color: var(--black); }
.fin-card.accent .val { color: var(--orange); }
.fin-card.accent .lbl { color: rgba(255,255,255,0.4); }

.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
th { text-align: left; padding: 10px 14px; background: var(--cream); font-weight: 500; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gray-dark); }
td { padding: 10px 14px; border-bottom: 1px solid var(--gray-pale); color: var(--gray-dark); }
tr:last-child td { border-bottom: none; font-weight: 600; color: var(--black); }
td.positive { color: #16a34a; font-weight: 600; }
td.negative { color: #dc2626; }

/* roadmap */
.roadmap-list { display: flex; flex-direction: column; gap: 0; }
.roadmap-item {
  display: grid; grid-template-columns: 120px 1fr;
  gap: 2rem; padding: 2rem 0;
  border-bottom: 1px solid var(--gray-pale);
  position: relative;
}
.roadmap-item:last-child { border-bottom: none; }
.phase-label {
  font-family: var(--font-display);
  font-size: 0.75rem; font-weight: 600; color: var(--orange);
  text-transform: uppercase; letter-spacing: 0.08em;
  padding-top: 3px;
}
.roadmap-h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; }
.roadmap-desc { font-size: 0.875rem; color: var(--gray-mid); line-height: 1.65; margin-bottom: 1rem; }
.milestone-chips { display: flex; flex-wrap: wrap; gap: 6px; }
.chip { background: var(--cream); border: 1px solid var(--gray-pale); padding: 4px 10px; font-size: 0.75rem; border-radius: 1px; color: var(--gray-dark); }

/* market */
.market-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
.market-card { border: 1px solid var(--gray-pale); padding: 1.5rem; border-radius: 2px; }
.market-card h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 600; margin-bottom: 1rem; }
.bar-item { margin-bottom: 14px; }
.bar-label { display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 5px; }
.bar-track { height: 6px; background: var(--gray-pale); border-radius: 0; }
.bar-fill { height: 100%; background: var(--orange); border-radius: 0; transition: width 1s ease; }
.bar-fill.teal { background: #0f766e; }
.bar-fill.blue { background: #2563eb; }

/* tech */
.tech-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
.tech-card { border: 1px solid var(--gray-pale); padding: 1.25rem; border-radius: 2px; }
.tech-card h4 { font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; color: var(--gray-mid); margin-bottom: 0.75rem; }
.tech-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
.tech-list li { font-size: 0.875rem; color: var(--gray-dark); display: flex; align-items: center; gap: 8px; }
.tech-list li::before { content: '→'; color: var(--orange); font-size: 0.7rem; }

/* ── TRUST ── */
#trust { background: var(--cream); }
.trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
.trust-card { background: var(--white); border: 1px solid rgba(0,0,0,0.06); padding: 1.75rem; border-radius: 2px; }
.trust-icon { font-size: 1.8rem; margin-bottom: 1rem; }
.trust-card h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
.trust-card p { font-size: 0.85rem; color: var(--gray-mid); line-height: 1.65; }

/* ── TESTIMONIALS ── */
#reviews { background: var(--white); padding: 5rem 3rem; }
.reviews-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
.review-card { border: 1px solid var(--gray-pale); padding: 1.5rem; border-radius: 2px; }
.review-stars { color: #f59e0b; font-size: 0.9rem; margin-bottom: 1rem; }
.review-text { font-size: 0.9rem; line-height: 1.7; color: var(--gray-dark); margin-bottom: 1.25rem; font-style: italic; }
.review-author { display: flex; align-items: center; gap: 10px; }
.review-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--orange); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 600; color: var(--white); }
.review-name { font-size: 0.875rem; font-weight: 500; }
.review-loc { font-size: 0.75rem; color: var(--gray-light); }

/* ── CTA SECTION ── */
#cta { background: var(--orange); padding: 5rem 3rem; text-align: center; }
#cta h2 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: var(--white); letter-spacing: -0.03em; margin-bottom: 1rem; }
#cta p { font-size: 1.1rem; color: rgba(255,255,255,0.75); margin-bottom: 2rem; }
.cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.btn-white { background: var(--white); color: var(--orange); padding: 0.9rem 2rem; border-radius: 2px; font-weight: 500; text-decoration: none; font-family: var(--font-body); transition: all 0.2s; }
.btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
.btn-white-outline { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.5); padding: 0.9rem 2rem; border-radius: 2px; font-weight: 500; text-decoration: none; font-family: var(--font-body); transition: all 0.2s; }
.btn-white-outline:hover { border-color: var(--white); }

/* ── FOOTER ── */
footer {
  background: var(--charcoal); color: rgba(255,255,255,0.5);
  padding: 3rem; display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem;
}
.footer-logo { font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; color: var(--white); margin-bottom: 0.75rem; }
.footer-logo span { color: var(--orange); }
.footer-desc { font-size: 0.85rem; line-height: 1.7; max-width: 260px; }
.footer-col h4 { font-size: 0.8rem; font-weight: 600; color: var(--white); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1rem; }
.footer-col a { display: block; font-size: 0.85rem; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 6px; transition: color 0.2s; }
.footer-col a:hover { color: var(--orange); }
.footer-bottom { background: var(--black); padding: 1rem 3rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: rgba(255,255,255,0.25); }

/* ── MODAL ── */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.7); z-index: 200;
  align-items: center; justify-content: center;
  padding: 1rem;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--white); max-width: 520px; width: 100%;
  border-radius: 2px; padding: 2.5rem; position: relative;
  max-height: 90vh; overflow-y: auto;
}
.modal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--gray-mid); }
.modal h2 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
.modal p { font-size: 0.875rem; color: var(--gray-mid); margin-bottom: 1.5rem; }
.form-group { margin-bottom: 1.2rem; }
.form-group label { display: block; font-size: 0.8rem; font-weight: 500; margin-bottom: 5px; color: var(--gray-dark); text-transform: uppercase; letter-spacing: 0.03em; }
.form-group input, .form-group select {
  width: 100%; padding: 0.7rem 0.9rem;
  border: 1px solid var(--gray-pale); border-radius: 2px;
  font-family: var(--font-body); font-size: 0.9rem; color: var(--black);
  outline: none; transition: border-color 0.2s;
}
.form-group input:focus, .form-group select:focus { border-color: var(--orange); }
.modal-tabs { display: flex; gap: 0; margin-bottom: 1.5rem; border: 1px solid var(--gray-pale); border-radius: 2px; overflow: hidden; }
.modal-tab { flex: 1; padding: 0.65rem; text-align: center; font-size: 0.875rem; cursor: pointer; transition: all 0.15s; }
.modal-tab.active { background: var(--black); color: var(--white); font-weight: 500; }

/* ── ANIMATIONS ── */
.fade-in { opacity: 0; transform: translateY(24px); transition: all 0.6s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }

/* ── MOBILE ── */
