<script>
/* ── CAR DATA ── */
const cars = [
  {emoji:'🚗',make:'Maruti Swift VXI',meta:'2022 · Petrol · Manual · Gurugram Sector 56',tags:['AC','Bluetooth','4 Seats'],price:'₹899',unit:'/day',rating:'4.9',trips:'87',badge:'',badgeType:''},
  {emoji:'🚙',make:'Hyundai Creta SX',meta:'2023 · Petrol · Automatic · Gurugram Sector 14',tags:['AC','Sunroof','5 Seats','GPS'],price:'₹1,799',unit:'/day',rating:'4.8',trips:'54',badge:'TOP RATED',badgeType:''},
  {emoji:'🛻',make:'Toyota Innova Crysta',meta:'2021 · Diesel · Manual · Delhi Dwarka',tags:['AC','7 Seats','Luggage','GPS'],price:'₹2,499',unit:'/day',rating:'4.7',trips:'132',badge:'',badgeType:''},
  {emoji:'🚗',make:'Honda City ZX',meta:'2023 · Petrol · CVT · Noida Sector 62',tags:['AC','Sunroof','5 Seats'],price:'₹1,399',unit:'/day',rating:'5.0',trips:'23',badge:'NEW',badgeType:'new'},
  {emoji:'⚡',make:'Tata Nexon EV',meta:'2024 · Electric · Automatic · Gurugram DLF',tags:['AC','EV','Fast Charge','5 Seats'],price:'₹1,999',unit:'/day',rating:'4.9',trips:'41',badge:'EV',badgeType:'new'},
  {emoji:'🚙',make:'Mahindra XUV 700',meta:'2023 · Diesel · Automatic · Delhi South',tags:['AC','7 Seats','ADAS','Sunroof'],price:'₹2,999',unit:'/day',rating:'4.8',trips:'19',badge:'PREMIUM',badgeType:''},
];

function renderCars(){
  document.getElementById('car-listings').innerHTML = cars.map(c=>`
    <div class="car-card" onclick="openModal('book')">
      <div class="car-img">
        <div class="car-img-bg"></div>
        ${c.badge?`<div class="car-badge ${c.badgeType}">${c.badge}</div>`:''}
        <div class="car-emoji">${c.emoji}</div>
      </div>
      <div class="car-info">
        <div class="car-make">${c.make}</div>
        <div class="car-meta">${c.meta}</div>
        <div class="car-tags">${c.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
        <div class="car-footer">
          <div class="car-price">${c.price}<span>${c.unit}</span></div>
          <div class="car-rating"><span class="star">★</span> ${c.rating} · ${c.trips} trips</div>
        </div>
      </div>
    </div>
  `).join('');
}

/* ── EARNINGS CALC ── */
function calcEarnings(){
  const days = +document.getElementById('days-slider').value;
  const price = +document.getElementById('price-slider').value;
  document.getElementById('days-val').textContent = days;
  document.getElementById('price-val').textContent = '₹'+price.toLocaleString('en-IN');
  const gross = days*price;
  const fee = Math.round(gross*0.25);
  const net = gross - fee - 1500;
  document.getElementById('gross').textContent = '₹'+gross.toLocaleString('en-IN');
  document.getElementById('fee').textContent = '−₹'+fee.toLocaleString('en-IN');
  document.getElementById('net').textContent = '₹'+net.toLocaleString('en-IN');
}

/* ── MODAL ── */
function openModal(type){
  const m = document.getElementById('modal');
  const b = document.getElementById('modal-body');
  if(type==='renter'){
    b.innerHTML=`
      <h2>Find your perfect car</h2>
      <p>Join 50,000+ renters on DriveMate. Signup takes 2 minutes.</p>
      <div class="modal-tabs"><div class="modal-tab active">Sign Up</div><div class="modal-tab" onclick="this.parentElement.querySelectorAll('.modal-tab').forEach(t=>t.classList.remove('active'));this.classList.add('active')">Log In</div></div>
      <div class="form-group"><label>Full Name</label><input type="text" placeholder="Rahul Sharma"></div>
      <div class="form-group"><label>Mobile Number</label><input type="tel" placeholder="+91 98765 43210"></div>
      <div class="form-group"><label>City</label><select><option>Gurugram</option><option>Delhi</option><option>Bengaluru</option><option>Mumbai</option><option>Hyderabad</option></select></div>
      <button class="btn-primary" style="width:100%" onclick="alert('OTP sent to your mobile! 🎉')">Send OTP →</button>
      <p style="text-align:center;margin-top:1rem;font-size:0.8rem;color:var(--gray-light)">By signing up you agree to our Terms & Privacy Policy</p>`;
  } else if(type==='host'){
    b.innerHTML=`
      <h2>List your car, start earning</h2>
      <p>Takes 10 minutes. Your car gets verified within 24 hours.</p>
      <div class="form-group"><label>Your Name</label><input type="text" placeholder="Priya Gupta"></div>
      <div class="form-group"><label>Mobile</label><input type="tel" placeholder="+91 98765 43210"></div>
      <div class="form-group"><label>Car Make & Model</label><input type="text" placeholder="Hyundai Creta SX 2023"></div>
      <div class="form-group"><label>Registration Number</label><input type="text" placeholder="HR 26 AB 1234"></div>
      <div class="form-group"><label>Expected daily price (₹)</label><input type="number" placeholder="1500"></div>
      <button class="btn-primary" style="width:100%" onclick="alert('Great! Our team will call you within 2 hours to complete verification 🚗')">Submit →</button>`;
  } else {
    b.innerHTML=`
      <h2>Book this car</h2>
      <p>Confirm your booking details below.</p>
      <div class="form-group"><label>Pick-up Date & Time</label><input type="datetime-local"></div>
      <div class="form-group"><label>Return Date & Time</label><input type="datetime-local"></div>
      <div class="form-group"><label>Purpose (optional)</label><select><option>Leisure / Weekend Trip</option><option>Outstation</option><option>Daily commute</option><option>Business meeting</option></select></div>
      <div style="background:var(--cream);padding:1rem;border-radius:2px;margin-bottom:1.2rem;font-size:0.875rem">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px"><span>2 days × ₹1,199</span><span>₹2,398</span></div>
        <div style="display:flex;justify-content:space-between;margin-bottom:6px"><span>Insurance</span><span>₹240</span></div>
        <div style="display:flex;justify-content:space-between;margin-bottom:6px"><span>Platform fee</span><span>₹120</span></div>
        <div style="display:flex;justify-content:space-between;font-weight:600;border-top:1px solid var(--gray-pale);padding-top:8px"><span>Total</span><span>₹2,758</span></div>
      </div>
      <button class="btn-primary" style="width:100%" onclick="alert('Redirecting to payment... 🔒')">Pay via UPI →</button>`;
  }
  m.classList.add('open');
}
function closeModal(){ document.getElementById('modal').classList.remove('open'); }
document.getElementById('modal').addEventListener('click',e=>{ if(e.target===e.currentTarget) closeModal(); });

/* ── PLAN TABS ── */
function showPlan(id){
  document.querySelectorAll('.plan-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.plan-tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('plan-'+id).classList.add('active');
  event.target.classList.add('active');
}

/* ── FADE IN ── */
const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible'); });
},{threshold:0.1});
document.querySelectorAll('.fade-in').forEach(el=>observer.observe(el));

renderCars();
calcEarnings();
</script>
